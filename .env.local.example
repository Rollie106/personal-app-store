# Copy this file to .env.local and fill in your real key for local dev with `vercel dev`.
# .env.local is gitignored. Never commit a file containing the real key.
#
# In PRODUCTION, the key is set in the Vercel dashboard:
#   Project Settings -> Environment Variables -> GEMINI_API_KEY
# It is NOT read from this file in production.

GEMINI_API_KEY=
